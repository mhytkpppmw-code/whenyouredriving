# Generate: openssl rand -base64 32
AUTH_SECRET=

# Production URL (no trailing slash). Local: http://localhost:3000
AUTH_URL=https://your-domain.com

# Your Apple ID email — only this address can sign in
ADMIN_EMAIL=you@icloud.com

# Sign in with Apple (Apple Developer account required)
AUTH_APPLE_ID=com.yourcompany.whenyouredriving
AUTH_APPLE_TEAM_ID=
AUTH_APPLE_KEY_ID=
# Paste .p8 key contents; use \n for line breaks in Vercel env vars
AUTH_APPLE_PRIVATE_KEY=